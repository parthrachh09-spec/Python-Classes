    "import random\n",
    "\n",
    "num= random.randint(1,10)\n",
    "if num%2==0:\n",
    "    print(\"Hint: Even\")\n",
    "else:\n",
    "    print(\"Hint: odd\")\n",
    "    \n",
    "guess=int(input(\"Enter your guess:\"))\n",
    "if num==guess:\n",
    "    print(\"You guessed it right. Won!!\")\n",
    "else:\n",
    "    print(\"You got it wrong.Number was\",num)"
